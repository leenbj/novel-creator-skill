{
  "id": "novel-claude-ai",
  "name": "Novel Claude AI - 小说创作大师",
  "description": "中文长篇小说全流程创作技能。当用户想写小说、创作故事、续写章节、构思剧情、搭建世界观、设计人物关系、提取写作风格、仿写其他小说时使用。覆盖从模糊想法到300万字成品的完整链路。",
  "version": "10.0.0",
  "activation": {
    "patterns": [
      "/novel-analyze", "/novel-create",
      "/一键开书", "/仿写", "/修复本章", "/继续写", "/新手模式",
      "/伏笔状态", "/修改章节", "/写作", "/写全篇", "/完整流程",
      "/建库", "/批量写作", "/拆书", "/时间线", "/更新记忆",
      "/校稿", "/检查一致性", "/更新剧情索引", "/剧情检索",
      "/检索记忆", "/续写", "/角色状态", "/门禁检查",
      "/题材选风格", "/风格库检索", "/风格提取", "/风格校准",
      "/风格迁移", "/评测基线", "/联网调研", "/一键写书",
      "/脑洞建图", "/改纲续写", "/双审",
      "小说创作", "拆书", "剧情检索", "百万字小说",
      "模糊剧情思路", "仿写", "生成大纲", "世界观构建",
      "写小说", "写故事", "续写", "写章节", "构思剧情",
      "人物关系", "写作风格", "帮我写个故事", "小说的想法",
      "故事大纲", "知识图谱", "脑洞"
    ],
    "triggers": [
      "用户希望最简单上手流程",
      "用户只有模糊剧情思路或一个灵感",
      "用户提供样章并要求模仿风格",
      "用户要求仿写或拆解小说",
      "用户需要创作、续写或批量写作小说",
      "用户需要修改章节或更新记忆",
      "用户需要检查一致性或风格校准",
      "用户需要门禁失败后的修复步骤",
      "用户需要写前自动匹配相关章节上下文",
      "用户需要评估流程性能",
      "用户想搭建世界观或设计人物关系",
      "用户想中途修改剧情大纲",
      "用户想全自动写一本书",
      "用户想提取或切换写作风格"
    ]
  },
  "capability_matrix": {
    "implemented": [
      "新手三命令", "五步质量门禁", "RAG剧情检索", "联网调研",
      "风格提取与复用", "基线评测"
    ],
    "partial": [
      "全自动写书", "小说仿写"
    ],
    "planned": [
      "交互式脑洞引导", "知识图谱", "大纲锚点", "多步流水线",
      "反向刹车", "事件冷却", "跨Agent审核", "中途改纲级联"
    ]
  },
  "memory_system": {
    "principle": "上下文窗口=内存（易失）；文件系统=磁盘（持久）",
    "smart_state": {
      "mandatory_reads": ["00_memory/novel_plan.md", "00_memory/novel_state.md"],
      "max_files_per_chapter": 4
    },
    "plot_retrieval": {
      "script": "scripts/plot_rag_retriever.py",
      "index_file": "00_memory/retrieval/story_index.json",
      "context_file": "00_memory/retrieval/next_plot_context.md"
    },
    "story_graph": {
      "file": "00_memory/story_graph.json",
      "schema": "references/story-graph-schema.md",
      "status": "planned"
    },
    "gate_artifacts": {
      "path": "04_editing/gate_artifacts/<chapter_id>/",
      "required_files": [
        "memory_update.md", "consistency_report.md",
        "style_calibration.md", "copyedit_report.md",
        "publish_ready.md", "gate_result.json"
      ],
      "verification_script": "scripts/chapter_gate_check.py"
    },
    "chapter_storage_policy": {
      "chapter_dir": "03_manuscript/",
      "rule": "章节必须保存到 03_manuscript/*.md，禁止混入 02_knowledge_base/"
    }
  },
  "executor": {
    "script": "scripts/novel_flow_executor.py",
    "one_click": "python3 scripts/novel_flow_executor.py one-click --project-root <项目目录> --title <书名> --genre <题材> --idea <剧情种子>",
    "continue_write": "python3 scripts/novel_flow_executor.py continue-write --project-root <项目目录> --query \"<新剧情>\""
  },
  "workflow": {
    "beginner_quickstart": ["/一键开书", "/继续写", "/修复本章"],
    "chapter_pipeline": [
      "/剧情检索", "/写作", "/更新记忆", "/检查一致性",
      "/风格校准", "/校稿", "/门禁检查", "/更新剧情索引"
    ],
    "planned_pipeline": [
      "锚点配额检查", "Beat Sheet生成", "Beat扩写",
      "章节合成", "门禁", "图谱回写", "跨Agent审核"
    ]
  },
  "compatibility": {
    "supported_tools": ["codex", "claude-code", "opencode", "gemini-cli", "antigravity"],
    "installer": "scripts/install-portable-skill.sh"
  }
}
